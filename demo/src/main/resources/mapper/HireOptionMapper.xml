<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.HireOptionMapper">
    <resultMap id="BaseResultMap" type="com.example.demo.entity.HireOption">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="label" property="label"/>
        <result column="duration_minutes" property="durationMinutes"/>
        <result column="price" property="price"/>
        <result column="display_order" property="displayOrder"/>
        <result column="is_active" property="isActive"/>
    </resultMap>

    <select id="findAllActive" resultMap="BaseResultMap">
        SELECT id, code, label, duration_minutes, price, display_order, is_active
        FROM hire_option
        WHERE is_active = TRUE
        ORDER BY display_order ASC, id ASC
    </select>

    <update id="update">
        UPDATE hire_option
        SET label = #{label},
            duration_minutes = #{durationMinutes},
            price = #{price},
            display_order = #{displayOrder},
            is_active = #{isActive}
        WHERE id = #{id}
    </update>
</mapper>
